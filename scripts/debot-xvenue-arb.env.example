# Template for debot-xvenue-arb.env — copy to /opt/debot/scripts/
# on debot-tokyo and fill in the credentials for the bot's dedicated
# sub-accounts. See docs/DESIGN.md §0 / §6.
#
# DO NOT commit the filled-in version. Secrets are KMS-wrapped via
# debot_utils::decrypt_data_with_kms at runtime using ENCRYPTED_DATA_KEY
# from debot_secrets_common.env.
#
# Strategy parameters live in YAML (configs/xvenue-arb/*.yaml). Pick
# one with $XVENUE_CONFIG_PATH below.

# --- Strategy / runtime ---
# Path to the YAML config (e.g. ETH primary or BTC secondary).
XVENUE_CONFIG_PATH=/opt/debot/configs/xvenue-arb/debot-xvenue-arb-eth.yaml

# KMS data key used to decrypt the *_PRIVATE_KEY entries below.
# Sourced from debot_secrets_common.env in production.
ENCRYPTED_DATA_KEY=

# Logger TZ offset (32400 = JST). Defaults to JST in main.rs.
TIMEZONE_OFFSET=32400

# --- Lighter (bot's Lighter sub-account — NEW wallet, see bot-strategy#234) ---
LIGHTER_PUBLIC_API_KEY=
LIGHTER_PRIVATE_API_KEY=            # KMS-encrypted
LIGHTER_API_KEY_INDEX=
LIGHTER_ACCOUNT_INDEX=              # optional — auto-discovered from wallet if unset
LIGHTER_WALLET_ADDRESS=
LIGHTER_EVM_WALLET_PRIVATE_KEY=     # KMS-encrypted — needed only for API key rotation

# Lighter REST / WS endpoints (defaults to mainnet if unset).
# REST_ENDPOINT=
# WEB_SOCKET_ENDPOINT=

# --- Extended (NEW sub-account, separated from debot-pair-btceth-extended) ---
EXTENDED_API_KEY=
EXTENDED_PUBLIC_KEY=
EXTENDED_PRIVATE_KEY=               # KMS-encrypted
EXTENDED_VAULT=
EXTENDED_REST_ENDPOINT=
EXTENDED_WEB_SOCKET_ENDPOINT=
