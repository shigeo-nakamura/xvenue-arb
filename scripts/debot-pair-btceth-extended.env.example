# Tokyo deploy env file template (bot-strategy#123).
# Copy to /opt/debot/scripts/debot-pair-btceth-extended.env on the Tokyo host
# and fill in the real values. The file must be chmod 600 and owned by
# ec2-user because it contains a KMS-wrapped private key.
#
# ENCRYPTED_DATA_KEY is loaded from /opt/debot/scripts/debot_secrets_common.env
# (inherited from the Frankfurt AMI), so it's NOT duplicated here.

# REST API key (plaintext, sent in X-Api-Key header)
EXTENDED_API_KEY=

# StarkNet account public key (hex, 0x...)
EXTENDED_PUBLIC_KEY=

# StarkNet private key, KMS-encrypted (base64). debot_utils::
# decrypt_data_with_kms unwraps it at runtime using ENCRYPTED_DATA_KEY.
EXTENDED_PRIVATE_KEY=

# Subaccount / vault id (u64)
EXTENDED_VAULT=

# Leave blank to use dex-connector's mainnet defaults.
REST_ENDPOINT=
WEB_SOCKET_ENDPOINT=
